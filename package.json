{
  "name": "platypus-mcp",
  "version": "0.0.1",
  "type": "module",
  "description": "Aggregated search MCP server (Brave, Exa, Tavily, Jina, SearXNG, Firecrawl)",
  "bin": {
    "platypus-mcp": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run tests/unit",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.100.1",
    "@google/genai": "^2.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "6.42.0",
    "undici": "^7.10.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "files": ["dist", "README.md"]
}
